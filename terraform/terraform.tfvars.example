# Copy this file to terraform.tfvars and fill in your own values
# cp terraform.tfvars.example terraform.tfvars

# AWS region — Singapore is closest for most students in Southeast Asia
aws_region = "ap-southeast-1"

# Short base name for your bucket — just use your own name, no uniqueness tricks needed!
# AWS (Mar 2026) now scopes bucket names to your account + region automatically.
# Terraform appends your Account ID, e.g. "gusto-bootcamp-john--123456789012"
bucket_base_name = "gusto-bootcamp-YOUR-NAME"
